# Copy this file to .env and fill in the values.
# Never commit .env to version control — it is listed in .gitignore.

# ─── Anthropic ───────────────────────────────────────────────────────────────
# API key used by the AI service to stream responses from Claude.
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Full URL of your Supabase project.
# Found in Project Settings → General → Reference ID, formatted as:
# https://<project-ref>.supabase.co
SUPABASE_URL=

# Service-role key for the Supabase project — grants full storage access.
# Found in Project Settings → API → service_role key.
# SECURITY: This key bypasses Row Level Security and has full read/write access
# to all data and storage. Never expose it to the browser or use it in any
# frontend environment variable (e.g. VITE_*).
SUPABASE_SERVICE_KEY=
